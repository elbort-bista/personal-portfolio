{
  "version": 2,
  "installCommand": "cd Frontend && npm ci",
  "buildCommand": "cd Frontend && npm run build",
  "outputDirectory": "Frontend/dist/public",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.ts": { "runtime": "nodejs20.x" }
  }
}
