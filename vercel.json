{
  "installCommand": "cd Frontend && npm ci",
  "buildCommand": "cd Frontend && npm run build",
  "outputDirectory": "Frontend/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": { "runtime": "nodejs20.x" }
  }
}
